# Comma-separated keys accepted in X-API-Key
API_KEYS=dev-key

# OpenAI-compatible base URL (vLLM or LiteLLM; must include /v1)
# https://docs.vllm.ai/projects/recipes/en/latest/Google/Gemma4.html#audio-transcription-openai-sdk
VLLM_BASE_URL=http://127.0.0.1:8001/v1
# Alternative env name (same setting as VLLM_BASE_URL):
# LITELLM_API_BASE=http://127.0.0.1:80/v1
VLLM_API_KEY=dummy
VLLM_TIMEOUT_SECONDS=120

# Defaults when the client omits a model (translate / vision / PDF / ASR)
DEFAULT_CHAT_MODEL=your-model-id
DEFAULT_TRANSLATE_MODEL=
DEFAULT_VISION_MODEL=
DEFAULT_SUMMARY_MODEL=
# ASR when STT_IMPLEMENTATION=vllm_gemma (e.g. google/gemma-4-E2B-it)
DEFAULT_AUDIO_MODEL=google/gemma-4-E2B-it

MAX_UPLOAD_MB=50

# stub | vllm_gemma — https://huggingface.co/google/gemma-4-E2B-it
STT_IMPLEMENTATION=stub
TTS_IMPLEMENTATION=stub
# stub | pdf_text (extract-text: PDF text only, not true OCR)
OCR_IMPLEMENTATION=stub

# Host port for nginx -> api (see docker-compose.yml)
HTTP_PORT=8080
